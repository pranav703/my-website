name: Deploy HTML Project

on:
  push:
    branches:
      - main  # Deploy when changes are pushed to the 'main' branch
  pull_request:
    branches:
      - main  # Optionally, deploy for PRs to 'main'

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      # Step 1: Checkout the repository
      - name: Checkout code
        uses: actions/checkout@v2

      # Step 2: Set up SSH (to connect to your Linux VM)
      - name: Set up SSH
        uses: webfactory/ssh-agent@v0.5.3
        with:
          ssh-private-key: ${{ secrets.SSH_PRIVATE_KEY }}

      # Step 3: Deploy the files to the VM (using rsync over SSH)
      - name: Deploy to server
        run: |
          rsync -avz --delete --exclude '.git' ./ user@your-vm-ip:/var/www/my-website
        env:
          RSYNC_RSH: 'ssh -o StrictHostKeyChecking=no'

      # Step 4: Restart Nginx (optional if the web server needs to be refreshed)
      - name: Restart Nginx
        run: |
          ssh user@your-vm-ip 'sudo systemctl restart nginx'

